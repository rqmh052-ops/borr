# انسخ هذا الملف إلى .env (محلياً فقط) ولا ترفعه أبداً لأي مستودع.
# على الاستضافة (Railway مثلاً): أضف نفس الأسماء من تبويب Variables
# في لوحة التحكم، ولا تكتب القيم هنا أو في الكود.

# توكن البوت من BotFather
BOT_TOKEN=123456789:your-bot-token-here

# آيدي حساب التيليجرام الخاص بالأدمن (رقم فقط)
ADMIN_ID=000000000

# آيدي قناة الاشتراك الإجباري (رقم سالب يبدأ بـ -100)
FORCE_SUB_CHANNEL_ID=-1000000000000

# رابط دعوة قناة الاشتراك الإجباري
FORCE_SUB_CHANNEL_URL=https://t.me/your_channel

# آيدي قناة قاعدة البيانات الخاصة (رقم سالب يبدأ بـ -100)
DB_CHANNEL_ID=-1000000000000
